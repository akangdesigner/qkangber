# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# RWD 稽核截圖（本地產物，23MB+）
.rwd-audit/

# 文章草稿與其圖片（本機作業用，發布走 Sheets/posts；不進版控避免 repo 變肥）
blog-drafts/

# Claude Code 本機設定（含權限白名單，可能含 token，不進版控）
.claude/settings.local.json
